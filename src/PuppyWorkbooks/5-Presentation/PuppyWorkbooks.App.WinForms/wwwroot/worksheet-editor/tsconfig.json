{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2020"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "js/generated",
    "declaration": false,
    "sourceMap": false,
    "removeComments": false
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "js/generated"]
}
